# Aurora-Chat 后端启动配置。
# 此处仅包含部署级别的值。SMTP、注册模式等运行时设置
# 由管理员通过 Web 界面配置并持久化到数据库中。

# ── HTTP 服务器 ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── 认证 ───────────────────────────────────────────────────────────────────
# 生产环境中请修改此项！
SECRET_KEY=please-change-this-secret-key

# ── 数据库 ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aurora_chat.db

# ── CORS ───────────────────────────────────────────────────────────────────
# 仅当浏览器直接与不同源的 FastAPI 通信时才需要此配置。
# 默认部署通过 Next.js 进程代理 /api 请求（参见 frontend/next.config.ts），
# 因此浏览器看到的是同源请求，CORS 实际上不起作用 —
# 将此列表保留为 localhost 以用于开发时的直接访问回退。
# 逗号分隔。开发环境可用 "*" 允许任何来源。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── 注册策略 ──────────────────────────────────────────────────────────────
# 可选的逗号分隔邮箱域名白名单。留空则接受任何域名。
ALLOWED_EMAIL_DOMAINS=

# ── 其他 ─────────────────────────────────────────────────────────────────
DEBUG=true
